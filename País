create table public."País" (
  id bigint generated by default as identity not null,
  "País" text null,
  constraint Relacionamento de tabelas_pkey primary key (id),
  constraint País_id_fkey foreign KEY (id) references "Empresa" (id),
  constraint País_id_fkey1 foreign KEY (id) references "TipoResfriamento" (id)
) TABLESPACE pg_default;
