create table public."Usuários" (
  id bigint generated by default as identity not null,
  "Número de usuários" text null,
  "IA" text null,
  "Empresa" text null,
  "País" text null,
  constraint Usuários_pkey primary key (id),
  constraint Usuários_id_fkey foreign KEY (id) references "País" (id)
) TABLESPACE pg_default;
